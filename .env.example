# OpenRouter API Key
OPENROUTER_API_KEY=

# LLM Provider: 'openrouter' | 'ollama' | 'gemini'
LLM_PROVIDER=openrouter
# If using gemini (Vertex AI), run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=

# Default models (OpenRouter free Nvidia model)
DEEP_THINK_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
QUICK_THINK_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# Ollama settings (if no OpenRouter key is provided)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEEP_THINK_MODEL=llama3.1:70b
# OLLAMA_QUICK_THINK_MODEL=llama3.1:8b

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Agent settings
MAX_DEBATE_ROUNDS=1
MAX_RISK_DISCUSS_ROUNDS=1
SELECTED_ANALYSTS=market,social,news,fundamentals

# API Request Throttling (for free OpenRouter tier 429 errors)
RATE_LIMIT_DELAY_MS=3000

# Paths
RESULTS_DIR=./results
DATA_CACHE_DIR=./data_cache
