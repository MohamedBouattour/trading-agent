{
  "name": "trading-agents-ts",
  "version": "1.0.0",
  "description": "TypeScript implementation of TradingAgents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "decide": "tsx src/decision-maker/decision-maker.ts",
    "bot": "tsx src/decision-maker/bot.ts",
    "bot:dry": "DRY_RUN=true tsx src/decision-maker/bot.ts",
    "build": "tsup",
    "build:bot": "tsup src/decision-maker/bot.ts --out-dir dist/bot",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@binance/connector": "^3.6.1",
    "@langchain/community": "^1.1.23",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/google-vertexai": "^2.1.25",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.13",
    "axios": "^1.13.6",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.3.1",
    "ink": "^6.8.0",
    "inquirer": "^13.3.0",
    "langchain": "^1.2.32",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "technicalindicators": "^3.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
